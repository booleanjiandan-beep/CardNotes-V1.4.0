<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android 11 and below (Auto Backup).
   For Android 12+ see data_extraction_rules.xml.
-->
<full-backup-content>
    <!-- Exclude database files from Auto Backup -->
    <exclude domain="database" path="note_database" />
    <exclude domain="database" path="note_database-shm" />
    <exclude domain="database" path="note_database-wal" />
    <!-- Include private images in device-to-device transfer -->
    <include domain="file" path="note_images" />
</full-backup-content>
