<?xml version="1.0" encoding="utf-8"?>
<!--
   Sample data extraction rules file; uncomment and update the rules as
   needed. For more information, see:
   https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Room database (will be restored separately) -->
        <exclude domain="database" path="note_database" />
        <exclude domain="database" path="note_database-shm" />
        <exclude domain="database" path="note_database-wal" />
        <!-- Exclude private images (too large for cloud backup) -->
        <exclude domain="file" path="note_images" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="note_images" />
        <include domain="database" path="note_database" />
    </device-transfer>
</data-extraction-rules>
